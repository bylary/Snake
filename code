void ncurses_init_colors() {
	// wi횆혲cej o kolorach tu https://www.linuxjournal.com/content/programming-color-ncurses

	// musimy ustawi횆혝 je캣혴li b횆혲dziemy u캣탄ywa횆혝 kolorowania konsoli
	start_color();
	// i zdefiniowa횆혝 pary kolor훯흢w kt훯흢re b횆혲dziemy u캣탄ywa횆혝
	init_pair(1, COLOR_GREEN, COLOR_BLACK);
}

void ncurses_config() {
	// definiujemy kolory tekstu kt훯흢re u캣탄yjemy do kolorowania planszy
	ncurses_init_colors();
	// getch ma interpretowa횆혝 znaki specjalne takie jak KEY_UP
	keypad(stdscr, TRUE);
	// ustawiamy timeout dla getch (milisekundy)
	// po tym czasie program przejdzie dalej nawet je캣혴li nie podasz klawisza
	timeout(500);
	// podczas wpisywania z klawiatury nie powinna si횆혲 drukowa횆혝 literka
	noecho();
}
class MainWindow {
	private:
		int wXR;
		int wYB;
		int wYU;
		int wXL;
		int score = 1;
	public:
		WINDOW * mainwin;

		void window(int yB, int xR, int yU, int xL) {
			wXR = xR;
			wYB = yB;
			wYU = yU;
			wXL = xL;
		}
		void ncurses_init_colors() {
			// wi횆혲cej o kolorach tu https://www.linuxjournal.com/content/programming-color-ncurses

			// musimy ustawi횆혝 je캣혴li b횆혲dziemy u캣탄ywa횆혝 kolorowania konsoli
			start_color();
			// i zdefiniowa횆혝 pary kolor훯흢w kt훯흢re b횆혲dziemy u캣탄ywa횆혝
			init_pair(1, COLOR_GREEN, COLOR_BLACK);
		}

		void addScore() {
			score +=1;
		}
		void print_board(std::vector<int> position_y, std::vector<int> position_x, int character, int length, int apple, int apple_x, int apple_y) {
			mainwin = newwin(wYB,wXR,wYU,wXL);


			for(int h=0; h<wYB-1; h++) {
				mvwprintw(mainwin, h, 0,"#");
				mvwprintw(mainwin, h, wXR-1,"#");

			}

			for(int w=0; w<wXR; w++) {
				mvwprintw(mainwin, 0, w,"#");
				mvwprintw(mainwin, wYB-1, w,"#");
			}



			char const* pchar = std::to_string(score).c_str();

			mvwprintw(mainwin, 0, 1,"SNAKE");
			mvwprintw(mainwin, 0, 7,"SCORE:");
			mvwprintw(mainwin, 0, 13, pchar);
			// operujemy na wirtualnym ekranie b횆혲d횆혚cym buforem ekranu
			// a nast횆혲pnie wy캣혴wietlamy bufor w terminalu funkcj횆혚 refresh

			//clear(); // czy캣혴ci wirtualny ekran (lepiej by캣혗o by czy캣혴ci횆혝 jeden znak albo jedna linie)

			attron(COLOR_PAIR(1)); // ustawiamy wcze캣혴niej zdefiniowan횆혚 per횆혲 kolor훯흢w
			// (mo캣탄na u캣탄y횆혝 mvaddch zamiast dw훯흢ch funcji)
			//move(position_y, position_x); // skaczemy kursorem do danej pozycji
			//addch(character); // drukujemy podany znak
//	movew(mainwin,apple_y,apple_x);
//	addch(apple);
			mvwaddch(mainwin,apple_y,apple_x, apple);
			for(int i=0; i < length; i++) {
				//move(position_y[i],position_x[i]);
				mvwaddch(mainwin,position_y[i],position_x[i],character);
				//move(position_y[i],position_x[i]+1);
				//addch(character);
			}

			move(0, 0); // aby migaj횆혚cy kursor nam nie przeszkadza캣혗fsdfsdfsadfsda
			attroff(COLOR_PAIR(1)); // przywracamy domy캣혴lny kolor

			//refresh(); // wy캣혴wietlamy zawarto캣혴횆혝 wirtualnego ekranu dopiero po refresh
		}
};
