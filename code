//			int x,y;
//			Coord(int x,int y):x(x),y(y) {
//			}
//		};
	private:
		std::vector<Coord> snake;

	public:
		void push(int x, int y) {
			snake.push_back(new Coord(x,y));

		}
		void moveVector() {
			int length = snake.size()-1;
			std::vector<Coord> tempSnake = snake;
			for(int i = 0; i < length-1; i++ ) {
				snake[length-i] = tempSnake[length-i-1];
			}
			//delete tempSnake;
		}
		void moveHead(Coord C) {
//			delete
			snake[0] = C;

		}

};

int letter(int character) {

	switch(character) {
		case 'S':
			return 'N';
		case 'N':
			return 'A';
		case 'A':
			return 'K';
		case 'K':
			return 'E';
		case 'E':
			return 'S';
		default:
			break;
	}
	return character;
}
int apple(Coord apple, Coord snakeHead) {
	if(apple.x == snakeHead.x && apple.y == snakeHead.y) {
		return true;
	}

	return false;
}

int main(void) {

	std::cout<<"\e[8;45;80t";
	// inicjalizacja ncurses//
	//WINDOW * mainwin = initscr();
	initscr();
	MainWindow mainwin = MainWindow();
	Snake snake;

	ncurses_config();



	int last_character = 'S';
	int last_position_x = 15;
	int last_position_y = 15;

	int upper_limit = 0;
	int bottom_limit = 25;
	int left_limit = 0;
	int right_limit = 50;
	int przegrana = false;

	mainwin.window(bottom_limit, right_limit, upper_limit,left_limit);

	snake= (last_position_x,last_position_y+1);
	snake.push(last_position_x,last_position_y);

	//int length  = 1;
	int apple_x = 20;
	int apple_y = 2;
	int apple_character = '@';
	int temporary = '*';

	while(1==1) {

		// sczytujemy literk횆혲 z klawiatury
		// (je캣혴li s횆혚 tu znaki specjalne musi by횆혝 int bo nie zmieszcz횆혚 si횆혲 w char)
		wclear(mainwin.mainwin);
		//mainwin.print();
		mainwin.print_board(snake_y, snake_x, temporary, snake_x.size(), apple_character, apple_x, apple_y);

		int input = getch();
		if(input != ERR) {
			switch(input) {
				case KEY_UP:
					if(apple((apple_x,apple_y),(last_position_x,last_position_y)) ==true) {
						mainwin.addScore();
						snake.push(last_position_x, last_position_y+1);
					}
					--last_position_y;
					snake.moveVector();
					snake.moveHead((last_position_x, last_position_y));
					break;
				case KEY_DOWN:
					if(apple(new Coord(apple_x,apple_y),new Coord(last_position_x,last_position_y)) ==true) {
						mainwin.addScore();
						snake.push(last_position_x, last_position_y-1);
					}
					++last_position_y;
					snake.moveVector();
					snake.moveHead(last_position_x,last_position_y);
					break;
				case KEY_LEFT:
					if(apple((apple_x,apple_y),(last_position_x,last_position_y)) ==true) {
						mainwin.addScore();
						snake.push(last_position_x+1, last_position_y);
					}
					--last_position_x;
					snake.moveVector();
					snake.moveHead(last_position_x,last_position_y);
					break;
				case KEY_RIGHT:
					if(apple(apple_x,apple_y,last_position_x,last_position_y) ==true) {
						mainwin.addScore();
						snake.push(last_position_x-1, last_position_y);
					}
					++last_position_x;
					snake.moveVector();
					snake.moveHead(last_position_x,last_position_y);
					break;
				default:
					break;
			}

		}

		if(last_position_x < left_limit+1) {
			last_position_x = right_limit-2;
			//przegrana = true;
		}
		if(last_position_x > right_limit-2) {
			last_position_x = left_limit+1;
			//przegrana = true;
		}
		if(last_position_y < upper_limit+1) {
			last_position_y = bottom_limit-2;
			//przegrana = true;
		}
		if(last_position_y > bottom_limit-2) {
			last_position_y = upper_limit+1;
			//przegrana = true;
		}



		//mainwin.print_board(snake_y, snake_x, temporary, snake_x.size(), apple_character, apple_x, apple_y);

		if(przegrana) {
			break;
		}
		wrefresh(mainwin.mainwin);



	}


	// zaka캣혙czamy prace ncurses
	delwin(mainwin.mainwin);
	endwin();
	refresh();
	return EXIT_SUCCESS;
}
